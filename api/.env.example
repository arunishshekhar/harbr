# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=harbr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=harbr

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string

# ─── Internal Registry ───────────────────────────────────────────────────────
# IP of the K3s node running the internal Docker registry on NodePort 30500
REGISTRY_IP=localhost

# ─── Ingress / Routing ───────────────────────────────────────────────────────
# K3s ships with Traefik as default ingress. Set INGRESS_CLASS to override.
INGRESS_CLASS=traefik

# cert-manager ClusterIssuer name (leave blank to disable automatic TLS)
# Example: letsencrypt-prod, letsencrypt-staging
CLUSTER_ISSUER=

# If using a pre-existing wildcard cert stored as a K8s secret, set its name.
# Example: wildcard-yourdomain-tls
TLS_WILDCARD_SECRET=

# ─── Cloudflare ──────────────────────────────────────────────────────────────
CLOUDFLARE_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Loki (optional — for log history) ───────────────────────────────────────
LOKI_URL=http://localhost:3100

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
